{
  "expo": {
    "name": "SupplyLink LK",
    "slug": "supplylink-lk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D6A4F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.supplylink.lk"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D6A4F"
      },
      "package": "com.supplylink.lk"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "supplylink"
  }
}
